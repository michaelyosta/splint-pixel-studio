# ═══════════════════════════════════════════════════════════════════════
# SPLINT Development Environment
# ═══════════════════════════════════════════════════════════════════════
#
# Quick start:
#   Copy-Item .env.example .env.local
#
# Then edit .env.local and enable dev auth:
#   ALLOW_DEV_AUTH=true
#   VITE_ALLOW_DEV_AUTH=true
#   SEED_DEMO_DATA=true
#
# Never commit .env.local. It is already in .gitignore.
# VITE_* variables must never contain secrets — they are bundled into the
# client bundle.

# ── Environment ────────────────────────────────────────────────────────
NODE_ENV=development

# ── Dev Auth ───────────────────────────────────────────────────────────
# Set both to "true" in .env.local to skip Telegram Mini Apps auth.
ALLOW_DEV_AUTH=false
VITE_ALLOW_DEV_AUTH=false
# User ID used by the frontend when dev auth is active.
VITE_DEV_USER_ID=user_pixelhunter

# ── Demo Data ─────────────────────────────────────────────────────────
SEED_DEMO_DATA=false
ALLOW_DESTRUCTIVE_DB_RESET=false

# ── Server ─────────────────────────────────────────────────────────────
PORT=3001

# ── Database ───────────────────────────────────────────────────────────
# Leave empty to use SQLite (file-backed, no Docker required).
# Set to postgresql://… after `docker compose up -d postgres`.
DATABASE_URL=
SQLITE_DB_PATH=

# ── Docker Compose — PostgreSQL ────────────────────────────────────────
POSTGRES_USER=splint
POSTGRES_PASSWORD=splint_dev_password
POSTGRES_DB=splint
POSTGRES_PORT=5432

# ── Docker Compose — MinIO (S3-compatible storage) ─────────────────────
MINIO_ROOT_USER=splint_minio
MINIO_ROOT_PASSWORD=splint_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=splint-originals
# Optional S3 credentials for private original-image storage.
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=splint_minio
S3_SECRET_ACCESS_KEY=splint_minio_password
S3_REGION=us-east-1

# ── Telegram (production only) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
