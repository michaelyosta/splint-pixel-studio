# Leave empty to use the file-backed local development database.
# Set this after `docker compose up -d postgres` to run PostgreSQL migrations.
DATABASE_URL=postgresql://splint:splint_dev_password@localhost:5432/splint
PORT=3001
TELEGRAM_BOT_TOKEN=
ALLOW_DEV_AUTH=true
# Optional MinIO / S3-compatible private original-image storage.
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=splint-originals
S3_ACCESS_KEY_ID=splint_minio
S3_SECRET_ACCESS_KEY=splint_minio_password
S3_REGION=us-east-1
