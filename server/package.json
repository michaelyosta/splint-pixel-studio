{
  "name": "splint-server",
  "version": "1.0.0",
  "description": "Splint Social Layer — Node.js/Express backend with SQLite",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "start:postgres": "node --env-file=.env index.js",
    "dev:postgres": "node --env-file=.env --watch index.js",
    "migrate": "node scripts/migrate.js",
    "migrate:postgres": "node --env-file=.env scripts/migrate-postgres.js",
    "bootstrap:system": "node bootstrap-system.js",
    "seed:demo": "node seed-demo.js",
    "reset:demo": "node reset-demo.js",
    "check": "node scripts/check.js",
    "test": "node --test test/*.test.js",
    "test:sqlite": "node --test test/*.test.js",
    "test:postgres": "node --env-file=.env --test test/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pg": "^8.13.1",
    "sql.js": "^1.12.0",
    "uuid": "^11.0.5"
  }
}
